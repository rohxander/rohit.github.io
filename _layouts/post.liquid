---
layout: default
---
<!-- Full Bleed Hero if present -->
{% if page.thumbnail %}
  <header class="post-header full-bleed-hero" style="background-image: url('{{ page.thumbnail | relative_url }}');">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description lead">{{ page.description }}</p>
      {% if page.date %}
      <p class="post-meta" style="color: var(--global-theme-color); font-weight: 800; font-family: 'Inter', sans-serif; letter-spacing: 0.05em; text-transform: uppercase;">
        {{ page.date | date: '%B %d, %Y' }}
      </p>
      {% endif %}
    </div>
  </header>
{% else %}
  <header class="post-header editorial-content text-left" style="margin-top: 6rem; margin-bottom: 2rem;">
    <h1 class="post-title" style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em; margin-bottom: 1rem;">{{ page.title }}</h1>
    <p class="post-description lead" style="font-size: 1.35rem; color: var(--global-text-muted);">{{ page.description }}</p>
    {% if page.date %}
    <p class="post-meta" style="color: var(--global-theme-color); font-weight: 800; font-family: 'Inter', sans-serif; letter-spacing: 0.05em; text-transform: uppercase; margin-top: 1rem;">
      {{ page.date | date: '%B %d, %Y' }}
    </p>
    {% endif %}
  </header>
{% endif %}

<!-- Editorial Content Body -->
<article class="editorial-content">
  {% if page.toc and page.toc.beginning %}
    <div id="table-of-contents" style="margin-bottom: 3rem; padding: 1.5rem; background: var(--global-code-bg-color); border-left: 4px solid var(--global-theme-color);">
      {% toc %}
    </div>
  {% endif %}
  
  <div id="markdown-content">
    {{ content }}
  </div>

  {% if page.related_publications %}
    <hr style="margin: 4rem 0; border-top: 2px solid var(--global-divider-color);">
    <h2>References</h2>
    <div class="publications">
      {% bibliography --group_by none --cited_in_order %}
    </div>
  {% endif %}

  {% if site.related_blog_posts and site.related_blog_posts.enabled %}
    {% if page.related_posts == null or page.related_posts %}
      <hr style="margin: 4rem 0; border-top: 2px solid var(--global-divider-color);">
      {% include related_posts.liquid %}
    {% endif %}
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</article>
